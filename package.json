{
  "name": "@agent-kit/toolcalls",
  "version": "0.1.0",
  "description": "Lightweight provider-aware tool call definitions and execution helpers for agent projects.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "src/tools/*/README.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools/memory-list": {
      "types": "./dist/tools/memory-list/tool.d.ts",
      "import": "./dist/tools/memory-list/tool.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
